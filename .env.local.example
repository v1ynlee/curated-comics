# ============================================================
# Comic Curated — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# Find your Supabase credentials at:
#   supabase.com → your project → Settings → API
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Required for all database operations and authentication.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Site URL ─────────────────────────────────────────────────
# Used for OG image URLs, RSS feed links, and metadata.
# In development: http://localhost:3000
# In production: your actual domain

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Cloudflare R2 Storage ────────────────────────────────────
# Server-side only — never exposed to client bundles.
# Used for media asset storage and CDN delivery.
#
# Find your credentials at:
#   Cloudflare Dashboard → R2 → Manage R2 API Tokens
#
# R2_ACCOUNT_ID      — Your Cloudflare account ID
# R2_ACCESS_KEY_ID   — Access key ID from an R2 API token
# R2_SECRET_ACCESS_KEY — Secret access key from an R2 API token
# R2_BUCKET_NAME     — Name of the R2 bucket for media storage
# R2_PUBLIC_URL      — Public CDN URL for serving R2 assets

R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://cdn.your-domain.com
