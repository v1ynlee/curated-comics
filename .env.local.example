# ============================================================
# Comic Curated — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# Supabase (required for Phase 1+)
NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT_ID>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<SUPABASE_KEY>
SUPABASE_SERVICE_ROLE=<eyJhb...l6pBHwOOwC690>

# Site URL (used for OG images and metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare R2 Storage (server-side only — never exposed to client bundles)
# Used for media asset storage and CDN delivery.
# Find your credentials at: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=<CLOUDFLARE_ACCOUNT_ID>
R2_ACCESS_KEY_ID=<R2_API_TOKEN_ACCESS_KEY_ID>
R2_SECRET_ACCESS_KEY=<R2_API_TOKEN_SECRET_ACCESS_KEY>
R2_BUCKET_NAME=<R2_BUCKET_NAME>
R2_PREFIX=platforms
R2_PUBLIC_URL=https://cdn.your-domain.com


# Gemini API Key
GEMINI_API_KEY="<your_gemini_api_key_here>"
GEMINI_MODEL="gemini-2.5-flash"

# Media delivery provider: local uses /public/platforms in development, r2 uses Cloudflare CDN.
MEDIA_PROVIDER=local
MEDIA_GENERATE_PLACEHOLDERS=true
